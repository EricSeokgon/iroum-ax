# iroum-ax 환경 변수 예시
# 실제 .env 파일은 이 파일을 복사하여 사용: cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 포함됨)

# =====================================================
# PostgreSQL (pgvector 포함)
# =====================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ax
POSTGRES_PASSWORD=devpass
POSTGRES_DB=iroum_ax

# =====================================================
# Redis (Celery 브로커 + 캐시)
# =====================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =====================================================
# 모델 디렉토리
# 로컬 환경: /models 또는 절대 경로
# Docker 환경: docker-compose.yml volumes 참조
# =====================================================
# 로컬 모델 저장 경로 (Qwen2-VL, Qwen 2.5, ko-sroberta)
MODEL_DIR=/models

# Hugging Face 캐시 디렉토리
HF_HOME=/models/hf_cache

# =====================================================
# LLM 모델 설정
# GPU 미사용 환경: transformers 직접 로딩 (아래 endpoint 비어 있으면 됨)
# GPU 환경: vLLM 서버 URL 지정 (docker compose --profile gpu up)
# =====================================================

# Qwen 2.5 7B (주 LLM — GPU 환경에서 vLLM 서버 사용)
# LLM_ENDPOINT=http://localhost:8101/v1

# Qwen2-VL 7B (VLM OCR — GPU 환경에서 vLLM 서버 사용)
# VLM_ENDPOINT=http://localhost:8100/v1

# =====================================================
# 보안 설정
# =====================================================
# PoC 단계: 인증 비활성화
AUTH_ENABLED=false

# =====================================================
# 로깅
# =====================================================
LOG_LEVEL=INFO
